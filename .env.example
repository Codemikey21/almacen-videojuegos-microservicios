@"
# ============================================
# Configuración General del Proyecto
# Almacén de Videojuegos - Microservicios
# ============================================

# --- API Gateway ---
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# --- Servicio Catálogo ---
CATALOGO_PORT=8001
CATALOGO_HOST=0.0.0.0
CATALOGO_DB_PATH=/app/data/catalogo.db

# --- Servicio Inventario ---
INVENTARIO_PORT=8002
INVENTARIO_HOST=0.0.0.0
INVENTARIO_DB_PATH=/app/data/inventario.db

# --- Servicio Órdenes ---
ORDENES_PORT=8003
ORDENES_HOST=0.0.0.0
ORDENES_DB_PATH=/app/data/ordenes.db

# --- URLs internas (Docker network) ---
CATALOGO_URL=http://servicio-catalogo:8001
INVENTARIO_URL=http://servicio-inventario:8002
ORDENES_URL=http://servicio-ordenes:8003

# --- Timeouts (segundos) ---
SERVICE_TIMEOUT=5

# --- Logging ---
LOG_LEVEL=INFO
"@ | Out-File -FilePath .env.example -Encoding utf8